# SPA shell: legacy (full maquette) | gateway (compliance UI + patient portal / portal booking test)
# VITE_SPA_MODE=legacy

# Optional: full API URL (skip Vite proxy). Default is same-origin /api.
# VITE_API_BASE=http://127.0.0.1:3000/api

# Optional: proxy target for vite.config.js (dev/preview only).
# VITE_PROXY_TARGET=http://127.0.0.1:3000

# Compliance gateway vendor URLs — public redirect/embed destinations only.
# Do not put secrets here.
VITE_VENDOR_BOOKING_URL=
VITE_VENDOR_TELEHEALTH_URL=
VITE_VENDOR_FORMS_URL=
VITE_VENDOR_DOCUMENTS_URL=
VITE_VENDOR_BILLING_URL=
VITE_PRIVACY_URL=

# Virtual session provider placeholders (demo only; do not commit real secrets)
VITE_ZOOM_CLIENT_ID=
VITE_ZOOM_CLIENT_SECRET=
VITE_ZOOM_ACCOUNT_ID=
VITE_ZOOM_WEBHOOK_SECRET=
VITE_DAILY_API_KEY=
VITE_WHEREBY_API_KEY=
VITE_TWILIO_ACCOUNT_SID=
VITE_TWILIO_AUTH_TOKEN=
VITE_TWILIO_PHONE_NUMBER=
VITE_TELNYX_API_KEY=
VITE_VONAGE_API_KEY=
# Optional local toggle: allow generated demo Jitsi rooms in Sessions Demo
VITE_ALLOW_JITSI_DEMO_ROOM=false
