# [MOCKUP PURPOSE ONLY - NOT REAL DATA]
NODE_ENV=development
PORT=3000
# Persistence: must be the string "true" or the API runs without DB (in-memory mock paths).
USE_PERSISTENCE=true
JWT_SECRET=psynova_dev_secret_change_me
JWT_EXPIRES_IN_SECONDS=3600

# DB_HOST: LOCAL MODE (Nest on your machine, Postgres via docker compose port publish) => localhost
# DOCKER MODE (API container) => use service name "db" (see docker-compose.yml; it overrides this file)
# Never rely on pool construction before ConfigModule; DatabaseService uses onModuleInit.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=psynova
DB_USER=psynova
DB_PASSWORD=psynova_password_change_me

# Translation (optional — at least one improves FR copies for staff-side demo)
# DeepL: https://www.deepl.com/pro-api
DEEPL_API_KEY=
# Optional override (default: https://api-free.deepl.com/v2/translate)
# DEEPL_API_URL=https://api.deepl.com/v2/translate
# Google Cloud Translation API key
GOOGLE_TRANSLATE_API_KEY=

# Comma-separated extra browser origins (e.g. your Vercel preview URL)
# CORS_ORIGINS=https://your-app.vercel.app

# Functional testing: skip token verification and inject a mock user (see AuthTokenGuard).
# Also bypasses when NODE_ENV=development.
# DISABLE_AUTH=true
