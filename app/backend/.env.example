# [MOCKUP PURPOSE ONLY - NOT REAL DATA]
NODE_ENV=development
PORT=3000
# Persistence: must be the string "true" or the API runs without DB (in-memory mock paths).
USE_PERSISTENCE=true
JWT_SECRET=psynova_dev_secret_change_me
JWT_EXPIRES_IN_SECONDS=3600

# DB_HOST: LOCAL MODE (Nest on your machine, Postgres via docker compose port publish) => localhost
# DOCKER MODE (API container) => use service name "db" (see docker-compose.yml; it overrides this file)
# Never rely on pool construction before ConfigModule; DatabaseService uses onModuleInit.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=psynova
DB_USER=psynova
DB_PASSWORD=psynova_password_change_me

# Translation (optional — at least one improves FR copies for staff-side demo)
# DeepL: https://www.deepl.com/pro-api
DEEPL_API_KEY=
# Optional override (default: https://api-free.deepl.com/v2/translate)
# DEEPL_API_URL=https://api.deepl.com/v2/translate
# Google Cloud Translation API key
GOOGLE_TRANSLATE_API_KEY=

# Comma-separated extra browser origins (e.g. your Vercel preview URL)
# CORS_ORIGINS=https://your-app.vercel.app

# Functional testing: skip token verification and inject a mock user (see AuthTokenGuard).
# Also bypasses when NODE_ENV=development.
# DISABLE_AUTH=true

# Compliance gateway vendor URLs — public redirect/embed destinations only.
# Do not put API keys or secrets here.
VENDOR_BOOKING_URL=
VENDOR_TELEHEALTH_URL=
VENDOR_FORMS_URL=
VENDOR_DOCUMENTS_URL=
VENDOR_BILLING_URL=
PRIVACY_URL=

# ============================================================================
# === Video providers (backup-video + telehealth launch)                   ===
# ============================================================================
# All endpoints fall back to a deterministic mock URL when the keys below are
# missing, so the demo flow stays 100% functional without any of these set.
# Adding keys flips the matching `mintXxxLive()` path on; see
# `app/backend/PROVIDER_SANDBOX_SETUP.md` for end-to-end signup steps.

# [FREE - DEV APP] Zoom Server-to-Server OAuth
# Marketplace -> Build App -> Server-to-Server OAuth. Required scopes:
#   meeting:write:admin meeting:read:admin user:read:admin
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_ACCOUNT_ID=
# [OPTIONAL] Webhook verification (only needed if you wire Zoom webhooks)
ZOOM_WEBHOOK_SECRET=

# Jane App WebCal / iCal subscription (escaleta v1 — POST /api/jane/sync)
# When empty, sync returns deterministic mock appointments.
JANE_ICAL_URL=

# [FREE TIER] Daily.co — STUB (live integration not yet implemented; key is read for readiness only)
DAILY_API_KEY=

# [FREE TIER] Whereby — STUB (live integration not yet implemented; key is read for readiness only)
WHEREBY_API_KEY=

# [FREE NO-AUTH] Public meet.jit.si rooms.
# When "true", GET /api/sessions/providers reports jitsi.configured=true and
# POST /api/sessions/backup-video {provider:"jitsi"} returns a real meet.jit.si URL.
JITSI_PUBLIC_DEMO_ROOM=true

# ============================================================================
# === Phone fallback (PSTN)                                                 ===
# ============================================================================
# Without any keys, /api/sessions/phone-fallback returns BACKUP_PHONE_NUMBER
# plus a deterministic 6-digit conference code. Adding Twilio trial keys
# enables real outbound voice calls (free to verified numbers on the trial).

# [TRIAL FREE] Twilio
# https://console.twilio.com -> Account info (SID + Auth Token) -> Phone Numbers
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
# Optional TwiML URL the callee hears. Defaults to http://demo.twilio.com/docs/voice.xml
TWILIO_TWIML_URL=

# [PAID - WIRED, NOT ACTIVATED] Telnyx
TELNYX_API_KEY=

# [PAID - WIRED, NOT ACTIVATED] Vonage
VONAGE_API_KEY=
VONAGE_API_SECRET=

# Mock callback number returned when no phone provider is configured.
# E.164 strongly recommended (e.g. +15145550100).
BACKUP_PHONE_NUMBER=+1-555-0100
